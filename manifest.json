{
  "manifest_version": 3,
  "name": "Universal Access",
  "version": "1.0.0",
  "description": "Transform web pages into clean, accessible interfaces using schema.org structured data.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-off-16.png",
      "48": "icons/icon-off-48.png",
      "128": "icons/icon-off-128.png"
    },
    "default_title": "Universal Access"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/nlweb-discovery.js",
        "content/schema-aggregation.js",
        "content/extractor.js",
        "content/schemamap.js",
        "content/transformer.js",
        "content/presets/presets.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/renderers/base.css",
        "content/presets/low-vision.css",
        "content/presets/dyslexia.css",
        "fonts/AtkinsonHyperlegible-Regular.woff2",
        "fonts/AtkinsonHyperlegible-Bold.woff2",
        "icons/icon-on.svg",
        "icons/icon-detection-no.svg",
        "icons/icon-detection-yes.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-off-16.png",
    "48": "icons/icon-off-48.png",
    "128": "icons/icon-off-128.png"
  }
}
